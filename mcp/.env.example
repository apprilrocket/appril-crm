# ── Conexión a Supabase (CRM) ──────────────────────────────────────────────
# El MCP usa la SERVICE ROLE key → BYPASSEA RLS. Por eso todo el scoping de
# workspace se hace manualmente en código (ver src/config.ts y src/db.ts).
SUPABASE_URL=https://hwiocriejizjdqqcfrsj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_sec_xxx_REEMPLAZAR

# Workspace activo del CRM (hoy es single-tenant).
APPRIL_WORKSPACE_ID=e2096477-fa6a-4b8f-a8b3-bd46ad720167

# ── Guardarraíles ──────────────────────────────────────────────────────────
# Direcciones permitidas para send_test (coma-separadas). El MCP SOLO puede
# enviar pruebas reales a estas direcciones; cualquier otra es rechazada.
MCP_TEST_ALLOWLIST=mauricio@todoc.co

# Identidad de auditoría: se escribe en created_by / triggered_by.
# (uuid de un crm_users de servicio; opcional, si vacío se omite created_by)
MCP_SERVICE_USER_ID=
